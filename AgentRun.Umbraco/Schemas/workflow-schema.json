{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Definition",
  "description": "Schema for AgentRun.Umbraco workflow.yaml files",
  "type": "object",
  "required": ["name", "description", "mode", "steps"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the workflow"
    },
    "description": {
      "type": "string",
      "description": "Description of what this workflow does"
    },
    "mode": {
      "type": "string",
      "enum": ["interactive", "autonomous"],
      "description": "Execution mode: interactive requires user input between steps, autonomous runs to completion"
    },
    "default_profile": {
      "type": "string",
      "description": "Default LLM profile to use for steps that don't specify one"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of workflow steps",
      "items": {
        "type": "object",
        "required": ["id", "name", "agent"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique step identifier (snake_case)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable step name"
          },
          "agent": {
            "type": "string",
            "description": "Relative path to the agent markdown file"
          },
          "profile": {
            "type": "string",
            "description": "LLM profile override for this step"
          },
          "tools": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tool names available to this step"
          },
          "reads_from": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Artifact file paths this step reads"
          },
          "writes_to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Artifact file paths this step produces"
          },
          "completion_check": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "files_exist": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Files that must exist for the step to be considered complete"
              }
            },
            "required": ["files_exist"]
          }
        }
      }
    }
  }
}
